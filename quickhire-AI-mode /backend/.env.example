# --- Server ---
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Database ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=quickhire

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT (RS256 or HS256) ---
# For production, RS256 is recommended with a private/public key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# For local development, you may use HS256 with a simple shared secret.
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...replace...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...replace...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
JWT_ISSUER=quickhire.services
JWT_AUDIENCE=quickhire-api

# --- AWS ---
AWS_REGION=ap-south-1
S3_BUCKET_CHAT=quickhire-chat-attachments
S3_BUCKET_INVOICES=quickhire-invoices
SQS_NOTIFICATION_URL=
SQS_INVOICE_URL=
SQS_EMAIL_URL=
SES_FROM=no-reply@quickhire.services

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# --- OTP / SMS ---
OTP_LENGTH=4
OTP_TTL_SECONDS=300
SMS_PROVIDER=mock
MSG91_AUTH_KEY=

# --- Misc ---
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=120

# --- Observability ---
# Get DSN from https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=
APP_VERSION=1.0.0

# --- AI Chatbot (Phase 5) ---
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Meilisearch (Phase 6) ---
# Run locally: docker run -p 7700:7700 getmeili/meilisearch:latest
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# --- Dev overrides ---
# Master OTP accepted in development — NEVER set in production
DEV_MASTER_OTP=1234
