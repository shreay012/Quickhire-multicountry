{
  "name": "quickhire-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "QuickHire backend - modular monolith (auth, booking, chat, payment, notification, admin)",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed.js",
    "worker:notifications": "node src/workers/notification.worker.js",
    "worker:invoice": "node src/workers/invoice.worker.js",
    "worker:email": "node src/workers/email.worker.js",
    "lint": "eslint src",
    "test": "node --test tests",
    "test:load": "k6 run k6/api-smoke.js",
    "test:burst": "k6 run k6/booking-burst.js",
    "test:sockets": "k6 run k6/socket-connections.js",
    "search:reindex": "node src/scripts/reindex.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/client-ses": "^3.658.0",
    "@aws-sdk/client-sns": "^3.658.0",
    "@aws-sdk/client-sqs": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@sentry/node": "^10.50.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bull-board": "^1.7.2",
    "bullmq": "^5.76.2",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.44.1",
    "mongodb": "^6.9.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "pdfkit": "^0.15.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.4",
    "stripe": "^16.0.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.10.0"
  }
}
